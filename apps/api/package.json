{
  "name": "@peopleos/api",
  "version": "0.1.0",
  "private": true,
  "description": "PeopleOS REST API — Node 20 + Fastify, Prisma, Zod, Clerk auth.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker": "tsx watch src/worker.ts",
    "worker:start": "node dist/worker.js",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.620.0",
    "@clerk/fastify": "^2.6.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.1.0",
    "@peopleos/schemas": "workspace:*",
    "@prisma/client": "^5.18.0",
    "bullmq": "^5.12.0",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "fastify-type-provider-zod": "^2.0.0",
    "ioredis": "^5.4.1",
    "pino": "^9.3.0",
    "undici": "^6.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "pino-pretty": "^11.2.0",
    "prisma": "^5.18.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
