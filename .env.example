# ───────────────────────────────────────────────────────────────────────────
# PeopleOS — local development environment
# Copy to .env and fill in. NEVER commit .env. In prod these come from
# AWS Secrets Manager (no secrets in containers or code — see spec Layer 6).
# ───────────────────────────────────────────────────────────────────────────

# ── Core datastores (docker-compose provides these locally) ──────────────────
DATABASE_URL="postgresql://peopleos:peopleos@localhost:5432/peopleos?schema=public"
# Separate role used by the API at request time — RLS policies apply to it.
# (The migration role / Prisma owner BYPASSES RLS, so never serve traffic with it.)
DATABASE_URL_APP="postgresql://peopleos_app:peopleos_app@localhost:5432/peopleos?schema=public"
REDIS_URL="redis://localhost:6379"
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="peopleos_neo4j"

# ── API ──────────────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST="0.0.0.0"
NODE_ENV="development"
LOG_LEVEL="info"

# JWT / Clerk (Phase 1 uses Clerk: email + Google OAuth).
# Leave CLERK_SECRET_KEY EMPTY for local dev: the API then accepts an `X-Org-Id`
# header for tenant context (see apps/api auth plugin), so you can drive it against
# the seed. Set a real key in staging/prod — once set, the X-Org-Id dev fallback is
# disabled so a header can never spoof a tenant.
CLERK_SECRET_KEY=""
CLERK_PUBLISHABLE_KEY="pk_test_replace_me"
JWT_ISSUER="https://peopleos.dev"

# ── AI service (Python FastAPI) ──────────────────────────────────────────────
AI_SERVICE_URL="http://localhost:8000"
# The Recruiter Copilot chat ReAct agent (Module 2c) calls BACK into the API's
# internal tool endpoints. The AI service needs the API base URL, and BOTH sides
# share AI_SERVICE_SECRET to authenticate that internal service-to-service traffic.
# (Internal endpoints are also expected to sit on a trusted/ACL'd network.)
PEOPLEOS_API_URL="http://localhost:3001"
AI_SERVICE_SECRET="dev-internal-service-secret-change-me"
ANTHROPIC_API_KEY="sk-ant-replace_me"
ANTHROPIC_MODEL="claude-sonnet-4-6"
OPENAI_API_KEY="sk-replace_me"
EMBEDDING_MODEL="text-embedding-3-large"

# LangSmith (LLM tracing + eval registry)
LANGSMITH_TRACING="true"
LANGSMITH_API_KEY="ls-replace_me"
LANGSMITH_PROJECT="peopleos-dev"

# Pinecone (vector store) — optional in Phase 1 slice; pgvector covers dev
PINECONE_API_KEY=""
PINECONE_INDEX="peopleos"

# ── Web ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_replace_me"

# ── Object storage (resumes / documents) ─────────────────────────────────────
S3_BUCKET="peopleos-dev"
S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_ENDPOINT="http://localhost:9000" # MinIO for local dev
